rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }

    function isDonor()       { return role() == 'donor'; }
    function isDriver()      { return role() == 'driver'; }
    function isBeneficiary() { return role() == 'beneficiary'; }

    // ── users ──────────────────────────────────────────────────────────────────
    // Each user can only read and write their own document.
    match /users/{userId} {
      allow read:   if isSignedIn() && uid() == userId;
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSignedIn() && uid() == userId;
      allow delete: if false;
    }

    // ── batches ────────────────────────────────────────────────────────────────
    // Open/claimed/pickedUp batches are readable by all signed-in users (map view,
    // volunteer queue). Delivered/closed batches are personal history — readable
    // only by the owning beneficiary, the donor, or the driver on that batch.
    match /batches/{batchId} {
      allow read: if isSignedIn() && (
        resource.data.status in ['open', 'claimed', 'pickedUp'] ||
        resource.data.beneficiaryId == uid() ||
        resource.data.donorId       == uid() ||
        resource.data.driverId      == uid()
      );

      allow create: if isSignedIn() && isDonor()
                    && request.resource.data.donorId == uid()
                    && request.resource.data.status == 'open';

      allow update: if isSignedIn() && (
        // Donor can update their own batch (e.g. edit before claimed)
        (isDonor() && resource.data.donorId == uid()) ||

        // Driver can claim an open batch (sets status → 'claimed', writes driverId)
        (isDriver() && resource.data.status == 'open'
          && request.resource.data.driverId == uid()) ||

        // Driver can advance their own claimed batch through pickup → delivered
        // Status values match the Dart enum serialisation: 'pickedUp' not 'picked_up'
        (isDriver() && resource.data.driverId == uid()
          && resource.data.status in ['claimed', 'pickedUp']) ||

        // Beneficiary can add rating/feedback and close their own batch.
        // diff().affectedKeys() checks only the fields being changed, not
        // all keys in the resulting document (which would always fail because
        // the batch document contains many more fields than the four allowed).
        (isBeneficiary() && resource.data.beneficiaryId == uid()
          && resource.data.status in ['delivered', 'closed']
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
               ['status', 'rating', 'feedback', 'updatedAt'])
          && (!('rating' in request.resource.data.diff(resource.data).affectedKeys())
              || (request.resource.data.rating is int
                  && request.resource.data.rating >= 1
                  && request.resource.data.rating <= 5))
          && (!('feedback' in request.resource.data.diff(resource.data).affectedKeys())
              || request.resource.data.feedback.size() <= 300))
      );

      allow delete: if false;
    }

    // ── driverLocations ────────────────────────────────────────────────────────
    // Driver writes only their own location doc; signed-in users can read.
    match /driverLocations/{driverId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && isDriver() && uid() == driverId;
    }

    // ── beneficiaries ──────────────────────────────────────────────────────────
    // All signed-in users read (donors need the full list for the map).
    // Only the owning beneficiary may create or update their own document.
    match /beneficiaries/{beneficiaryId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && isBeneficiary() && uid() == beneficiaryId;
      allow update: if isSignedIn() && isBeneficiary() && uid() == beneficiaryId;
      allow delete: if false;
    }

    // ── impactMetrics ──────────────────────────────────────────────────────────
    // Cloud Functions write these; clients only read own doc + global.
    match /impactMetrics/{docId} {
      allow read:  if isSignedIn()
                   && (docId == 'global' || docId == uid());
      allow write: if false;
    }

    // ── leaderboard ────────────────────────────────────────────────────────────
    // Updated client-side by drivers after each delivery (confirmDelivery
    // transaction). Any signed-in driver may read and write so the ranking
    // is rebuilt in real time without a Cloud Function.
    match /leaderboard/{period} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && isDriver();
    }
  }
}
