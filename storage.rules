rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // batch item photos uploaded by donors
    match /batches/{batchId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // pickup confirmation photos uploaded by drivers (path: batch_photos/{batchId}/pickup.jpg)
    match /batch_photos/{batchId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // delivery confirmation photos uploaded by drivers
    match /deliveries/{batchId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // profile photos and org banner photos uploaded by donors
    match /users/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
