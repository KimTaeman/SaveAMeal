rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // batch photos: any signed-in user can read; only donors can upload to their own batch folder
    match /batches/{batchId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024   // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // delivery confirmation photos uploaded by drivers
    match /deliveries/{batchId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
